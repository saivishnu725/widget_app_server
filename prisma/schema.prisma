// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String           @id @default(uuid()) @db.Uuid
  email         String           @unique
  password_hash String
  name          String
  created_at    DateTime         @default(now())
  updated_at    DateTime         @updatedAt
  
  widgets       Widget[]         @relation("WidgetOwner")
  state_logs    WidgetStateLog[] @relation("LogChangedBy")
}

model Widget {
  id              String           @id @default(uuid()) @db.Uuid
  owner_id        String           @db.Uuid
  name            String
  emoji           String
  shared_user_ids String[]         @db.Uuid
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt

  owner           User             @relation("WidgetOwner", fields: [owner_id], references: [id])
  logs            WidgetStateLog[]
}

model WidgetStateLog {
  id         String   @id @default(uuid()) @db.Uuid
  widget_id  String   @db.Uuid
  new_state  String
  changed_by String   @db.Uuid
  changed_at DateTime @default(now())

  widget     Widget   @relation(fields: [widget_id], references: [id], onDelete: Cascade)
  user       User     @relation("LogChangedBy", fields: [changed_by], references: [id])
}
